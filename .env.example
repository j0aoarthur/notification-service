# =========================================================
# Notification Service — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores.
# =========================================================

# -------------------------
# RabbitMQ (Message Broker)
# -------------------------
RABBITMQ_URI=amqp://guest:guest@localhost:5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# Nome da fila principal de notificações
RABBITMQ_QUEUE=notifications_queue

# Nome da fila de retentativa (Dead Letter Exchange)
RABBITMQ_RETRY_QUEUE=notifications_retry_queue

# Nome da fila de mensagens permanentemente falhas (Dead Letter Queue)
RABBITMQ_DEAD_QUEUE=notifications_dead_queue

# Tempo de espera em ms antes de retentar uma mensagem (padrão: 30 segundos)
RABBITMQ_RETRY_TTL_MS=30000

# Número máximo de tentativas antes de mover para a DLQ
RABBITMQ_MAX_RETRIES=5

# -------------------------
# SMTP (Entrega de E-mail)
# -------------------------
# Para desenvolvimento local, use MailHog (porta 1025) via docker-compose
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@notification-service.local
